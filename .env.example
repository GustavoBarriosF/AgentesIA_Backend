# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# MongoDB
MONGODB_URI=mongodb://localhost:27017/trivoxchat

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-to-a-long-random-secret-at-least-64-chars
JWT_EXPIRES_IN=24h

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# ── Ollama (LLM local) ──────────────────────────────────────────────────────
# URL del servidor Ollama (incluye puerto)
OLLAMA_URL=http://216.219.91.106:11434
# Modelo a usar para embeddings RAG (debe estar descargado en el servidor Ollama)
OLLAMA_EMBED_MODEL=llama3.2:1b

# ── Qdrant (base de datos vectorial para RAG) ───────────────────────────────
QDRANT_URL=http://216.219.91.106:6333
QDRANT_API_KEY=your-qdrant-api-key-here

# Meta / WhatsApp Business
# IMPORTANTE: En esta plataforma SaaS cada cliente configura su propia Meta App.
# Las credenciales (phone_number_id, access_token, app_secret, verify_token)
# se guardan en channel.config de cada canal WhatsApp, NO aqui como variables globales.
META_GRAPH_API_VERSION=v18.0

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=trivoxchat-files
R2_PUBLIC_URL=https://files.yourdomain.com

# Email (Resend o SendGrid)
EMAIL_PROVIDER=resend
RESEND_API_KEY=re_...
FROM_EMAIL=noreply@yourdomain.com

# Firebase Cloud Messaging (push notifications)
FCM_SERVER_KEY=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Super Admin (ejecutar: npm run seed para crear el primer admin y los planes)
SUPERADMIN_JWT_SECRET=change-me-to-a-long-random-secret-superadmin-only
SUPERADMIN_EMAIL=admin@trivoxchat.com
SUPERADMIN_PASSWORD=change-me-strong-password
SUPERADMIN_NAME=Super Admin

# URLs públicas
FRONTEND_URL=http://localhost:3001
PUBLIC_APP_URL=https://app.trivoxchat.com
PUBLIC_API_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# ── Slack y Microsoft Teams ──────────────────────────────────────────────────
# No hay credenciales globales: cada cliente crea su propia Slack App / Azure Bot
# y configura las credenciales en su canal (channel.config).
# Slack:  bot_token, signing_secret, team_id  →  canal tipo 'slack'
# Teams:  app_id, app_password                →  canal tipo 'teams'
